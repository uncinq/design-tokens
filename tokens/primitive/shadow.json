{
  "shadow": {
    "none": {
      "$value": "none",
      "$type": "shadow"
    },
    "sm": {
      "$value": "0 1px 2px 0 {color.shadow.normal}",
      "$type": "shadow"
    },
    "md": {
      "$value": "0 4px 6px -1px {color.shadow.normal}, 0 2px 4px -2px {color.shadow.normal}",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0 10px 15px -3px {color.shadow.normal}, 0 4px 6px -4px {color.shadow.normal}",
      "$type": "shadow"
    },
    "center": {
      "sm": {
        "$value": "0 0 2px  2px  {color.shadow.normal}",
        "$type": "shadow"
      },
      "md": {
        "$value": "0 0 5px  5px  {color.shadow.normal}",
        "$type": "shadow"
      },
      "lg": {
        "$value": "0 0 10px 10px {color.shadow.normal}",
        "$type": "shadow"
      }
    }
  }
}
