{
  "font": {
    "family": {
      "$type": "fontFamily",
      "mono": {
        "$value": "ui-monospace, monospace"
      },
      "sans": {
        "$value": "system-ui, sans-serif"
      },
      "serif": {
        "$value": "Georgia, serif"
      }
    },
    "weight": {
      "$type": "number",
      "thin": {
        "$value": "100"
      },
      "light": {
        "$value": "300"
      },
      "normal": {
        "$value": "400"
      },
      "medium": {
        "$value": "500"
      },
      "semibold": {
        "$value": "600"
      },
      "bold": {
        "$value": "700"
      },
      "black": {
        "$value": "900"
      }
    }
  },
  "line": {
    "height": {
      "$type": "number",
      "none": {
        "$value": "1"
      },
      "tight": {
        "$value": "1.1"
      },
      "snug": {
        "$value": "1.25"
      },
      "normal": {
        "$value": "1.5"
      },
      "relaxed": {
        "$value": "1.75"
      },
      "loose": {
        "$value": "2"
      }
    }
  },
  "text": {
    "decoration": {
      "$type": "string",
      "none": {
        "$value": "none"
      },
      "underline": {
        "$value": "underline"
      },
      "offset": {
        "$value": "0.25rem"
      },
      "thickness": {
        "$value": "1px"
      }
    }
  }
}
