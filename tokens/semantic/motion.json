{
  "duration": {
    "fast": {
      "$value": "150ms",
      "$type": "duration"
    },
    "normal": {
      "$value": "300ms",
      "$type": "duration"
    },
    "slow": {
      "$value": "600ms",
      "$type": "duration"
    }
  },
  "easing": {
    "linear": {
      "$value": "linear",
      "$type": "string"
    },
    "default": {
      "$value": "ease-in-out",
      "$type": "string"
    },
    "in": {
      "$value": "ease-in",
      "$type": "string"
    },
    "out": {
      "$value": "ease-out",
      "$type": "string"
    },
    "out-circ": {
      "$value": "cubic-bezier(0, 0.55, 0.45, 1)",
      "$type": "string"
    },
    "out-expo": {
      "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
      "$type": "string"
    },
    "out-back": {
      "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "$type": "string"
    },
    "bounce": {
      "$value": "cubic-bezier(0.165, 0.84, 0.44, 1)",
      "$type": "string"
    },
    "spring": {
      "$value": "linear(\n      0, 0.006, 0.025 2.8%, 0.101, 0.197, 0.325, 0.474, 0.638, 0.806,\n      0.962, 1.065, 1.12, 1.14, 1.12 30.9%, 1.034, 0.997, 0.986, 0.998, 1\n    )",
      "$type": "string"
    }
  },
  "blur": {
    "overlay": {
      "$value": "4px",
      "$type": "dimension"
    }
  },
  "transition": {
    "fast": {
      "$value": "all {duration.fast}   {easing.default}",
      "$type": "string"
    },
    "normal": {
      "$value": "all {duration.normal} {easing.default}",
      "$type": "string"
    },
    "slow": {
      "$value": "all {duration.slow}   {easing.default}",
      "$type": "string"
    },
    "opacity": {
      "$value": "opacity   {duration.normal} {easing.default}",
      "$type": "string"
    },
    "transform": {
      "$value": "transform {duration.normal} {easing.default}",
      "$type": "string"
    },
    "property": {
      "color": {
        "$value": "color, background-color, border-color, outline-color, fill, stroke, text-decoration",
        "$type": "string"
      }
    },
    "color": {
      "$value": "{transition.property.color} {duration.normal} {easing.default}",
      "$type": "string"
    }
  }
}
